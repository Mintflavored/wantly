# Wantly nginx config — HTTP-only template.
#
# certbot --nginx автоматически добавит TLS directives (listen 443 ssl,
# ssl_certificate paths, HTTP→HTTPS redirect) при первом запуске.
# НЕ добавляйте TLS блок вручную — certbot управляет им сам.
#
# Install: cp wantlyapp.ru.nginx /etc/nginx/sites-available/wantlyapp.ru
# Then run: certbot --nginx -d wantlyapp.ru -d www.wantlyapp.ru

server {
    listen 80;
    listen [::]:80;
    server_name wantlyapp.ru www.wantlyapp.ru;

    # Proxy headers на server level — применяются ко всем location (включая
    # /health/ready), чтобы rate-limiting работал корректно.
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
    }

    location /health {
        proxy_pass http://127.0.0.1:8080;
    }

    # Android App Links verification: Android 12+ требует
    # https://wantlyapp.ru/.well-known/assetlinks.json с SHA-256 fingerprint
    # сертификата app. alias указывает на конкретный файл (не root).
    location /.well-known/assetlinks.json {
        alias /opt/wantly-backend/deploy/assetlinks.json;
        default_type application/json;
    }

    location / {
        return 200 'Wantly API';
        add_header Content-Type text/plain;
    }
}
