server {
    listen 80;
    listen [::]:80;
    server_name wantlyapp.ru www.wantlyapp.ru;

    # Proxy headers на server level — применяются ко всем location (включая
    # /health/ready), чтобы rate-limiting работал корректно. Если ставить их
    # только в /api/, то /health/ready получит client-supplied X-Real-IP и
    # attacker сможет ротировать IP для обхода лимита (codex P1).
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
    }

    location /health {
        proxy_pass http://127.0.0.1:8080;
    }

    # Android App Links verification: Android 12+ требует
    # https://wantlyapp.ru/.well-known/assetlinks.json с SHA-256 fingerprint
    # сертификата app. Без этого verified deep-link не работает и share-link
    # открывается в браузере. alias указывает на конкретный файл (не root —
    # иначе nginx искал бы .well-known/assetlinks.json внутри deploy/).
    # Реальный файл (не .example) нужно создать при deploy через keytool.
    location /.well-known/assetlinks.json {
        alias /opt/wantly-backend/deploy/assetlinks.json;
        default_type application/json;
    }

    location / {
        return 200 'Wantly API';
        add_header Content-Type text/plain;
    }
}
